generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quote {
  id             String   @id @default(cuid())
  clientName     String
  clientContact  String
  projectName    String
  purpose        String?
  dimensions     String?
  preferredColor String?
  description    String?
  fileUrl        String?
  externalLink   String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model Material {
  id              String    @id @default(cuid())
  name            String
  type            String
  color           String?
  costPerUnit     Float
  totalAmount     Float
  remainingAmount Float
  unitType        String
  syncTest        String?   @default("ok")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  products        Product[]
}

model Product {
  id             String      @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?
  productionTime Int
  weightGrams    Float
  additionalCost Float       @default(0)
  materialId     String
  category       String      @default("Geral")
  subcategory    String?
  sku            String?     @unique
  shopeeUrl      String?
  calculatedCost Float
  sellingPrice   Float
  stockQuantity  Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
  material       Material    @relation(fields: [materialId], references: [id])
  
  parentId       String?
  parent         Product?    @relation("ProductVariations", fields: [parentId], references: [id])
  variations     Product[]   @relation("ProductVariations")

  // Composição de Kits
  components     ProductComposition[] @relation("KitComponents")
  usedIn         ProductComposition[] @relation("ComponentOf")
}

model ProductComposition {
  id          String  @id @default(cuid())
  kitId       String
  componentId String
  quantity    Int     @default(1)
  
  kit         Product @relation("KitComponents", fields: [kitId], references: [id])
  component   Product @relation("ComponentOf", fields: [componentId], references: [id])
  
  @@unique([kitId, componentId])
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerContact String?
  status          String      @default("PENDING")
  type            String      @default("ORDER")
  totalAmount     Float
  discountAmount  Float       @default(0)
  deadline        DateTime?
  notes           String?
  weightGrams     Float?
  materialId      String?
  paymentStatus   String      @default("UNPAID")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String?
  quantity   Int
  price      Float
  customName String?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  description String?
  date        DateTime @default(now())
}

model Config {
  key   String @id
  value String
}

model Printer {
  id           String        @id @default(cuid())
  name         String
  model        String
  type         String        @default("FDM")
  price        Float         @default(0)
  lifespan     Int           @default(5000)
  powerW       Int           @default(250)
  depreciation Float         @default(0)
  totalHours   Float         @default(0.0)
  status       String        @default("OPERATIONAL")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  maintenances Maintenance[]
}

model Maintenance {
  id          String   @id @default(cuid())
  printerId   String
  description String
  cost        Float    @default(0)
  date        DateTime @default(now())
  printer     Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
}

