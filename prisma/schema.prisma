generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quote {
  id             String   @id @default(cuid())
  clientName     String
  clientContact  String
  projectName    String
  purpose        String?
  dimensions     String?
  preferredColor String?
  description    String?
  fileUrl        String?
  externalLink   String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
}

model Material {
  id              String    @id @default(cuid())
  name            String
  type            String
  color           String?
  costPerUnit     Float
  totalAmount     Float
  remainingAmount Float
  unitType        String
  syncTest        String?   @default("ok")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  products        Product[]
}

model Product {
  id             String      @id @default(cuid())
  name           String
  description    String?
  imageUrl       String?
  productionTime Int
  weightGrams    Float
  additionalCost Float       @default(0)
  materialId     String
  category       String      @default("Geral")
  subcategory    String?
  sku            String?     @unique
  shopeeUrl      String?
  calculatedCost Float
  sellingPrice   Float
  stockQuantity  Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  orderItems     OrderItem[]
  material       Material    @relation(fields: [materialId], references: [id])
  
  parentId       String?
  parent         Product?    @relation("ProductVariations", fields: [parentId], references: [id])
  variations     Product[]   @relation("ProductVariations")
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerContact String?
  status          String      @default("PENDING")
  type            String      @default("ORDER")
  totalAmount     Float
  discountAmount  Float       @default(0)
  deadline        DateTime?
  notes           String?
  weightGrams     Float?
  materialId      String?
  paymentStatus   String      @default("UNPAID")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           OrderItem[]
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String?
  quantity   Int
  price      Float
  customName String?
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  category    String
  amount      Float
  description String?
  date        DateTime @default(now())
}

model Config {
  key   String @id
  value String
}
